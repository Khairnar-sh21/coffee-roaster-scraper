def get_roast_level(text):
    text = text.lower()
    if 'medium light' in text or 'light medium' in text or 'blonde' in text:
        return 'Medium Light'
    if 'medium dark' in text or 'dark medium' in text or 'espresso roast' in text:
        return 'Medium Dark'
    if 'light' in text or 'filter roast' in text:
        return 'Light'
    if 'dark' in text or 'french' in text:
        return 'Dark'
    if 'medium' in text:
        return 'Medium'
    return None


def get_origins(text):
    text = text.lower()
    # Never treat "Global" as a real origin keyword signal.
    # "Global" is returned only when no other origin keywords are found.
    found = [o for o in ORIGINS_LIST if o.lower() in text and o.lower() != 'global']
    return found if found else ['Global']


def _extract_weight_phrases_from_text(text):
    """Return substrings like '12 oz', '4.5oz', '2 lb' for get_quantities()."""
    if not text:
        return []
    out = []
    for m in re.finditer(
        r'\d+(?:\.\d+)?\s*(?:lb|lbs|pound|pounds|oz|ounce|ounces|g|gram|grams)\b',
        str(text),
        re.I,
    ):
        out.append(m.group(0))
    return out


def _strip_wordpress_seo_title_suffix(title, roaster_display_name=None):
    """
    Remove trailing site / SEO suffixes often added by WordPress themes or Yoast, e.g.
    'Product Name - Cutbow Coffee' or 'Product Name | Site Name'.
    """
    if not title:
        return title
    t = re.sub(r'\s+', ' ', str(title).strip())
    # Strip using known roaster display name from Airtable
    if roaster_display_name:
        rn = roaster_display_name.strip()
        if rn:
            pat = re.compile(
                r'\s*(?:\s*[-|–—]\s*|\s*\|\s*)' + re.escape(rn) + r'\s*$',
                re.I,
            )
            t = pat.sub('', t).strip()
    return t


def get_quantities(shopify_values):
    """
    Normalize free-form size strings (e.g. '2 lbs', '16 ounces', '250 grams')
    into the canonical forms defined in QUANTITY_OPTIONS (e.g. '2 lb', '16 oz', '250g').
    Applied generically across all platforms.
    """
    import re

    def _normalize_quantity_string(s):
        if not s:
            return None
        v = str(s).lower()
        # Find "<number><optional space><unit>"
        m = re.search(r'(\d+(?:\.\d+)?)\s*(lb|lbs|pound|pounds|oz|ounce|ounces|g|gram|grams)', v)
        if not m:
            return None
        num, unit = m.groups()
        # Canonicalize unit
        if unit in ('lb', 'lbs', 'pound', 'pounds'):
            base_unit = 'lb'
        elif unit in ('oz', 'ounce', 'ounces'):
            base_unit = 'oz'
        else:  # grams
            base_unit = 'g'
        # Use a compact normalized key like "2lb", "16oz", "250g"
        return f'{num}{base_unit}'

    # Precompute normalized forms for all allowed quantity options
    option_by_norm = {}
    for q in QUANTITY_OPTIONS:
        norm_q = _normalize_quantity_string(q)
        if norm_q:
            option_by_norm[norm_q] = q

    found = set()
    for val in shopify_values:
        norm = _normalize_quantity_string(val)
        if norm and norm in option_by_norm:
            found.add(option_by_norm[norm])

    return list(found)


def get_types(shopify_values):
    found = []
    text = ' '.join(shopify_values or []).lower()
    if 'whole' in text or 'bean' in text:
        found.append('Whole Bean')
    if 'ground' in text or 'drip' in text or 'espresso' in text:
        found.append('Ground')
    return list(set(found))


def option_name_is_grind_or_bean_type(name):
    """
    True if a Shopify option name or WooCommerce attribute name indicates grind / preparation.

    Matches e.g. 'Grind', 'Coffee grind', 'BEAN TYPE', 'Bean type', 'bean-type'.
    Used so we still collect Whole Bean / Ground when the store never uses the word 'grind'.
    """
    if not name:
        return False
    n = str(name).lower()
    if 'grind' in n:
        return True
    if 'bean' in n and 'type' in n:
        return True
    return False


