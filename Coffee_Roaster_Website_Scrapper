def extract_structured_fields_from_html(html_text):
    """
    Returns a dict with optional keys:
      - 'origin_text'
      - 'roast_text'
      - 'quantity_texts' (list)
      - 'grind_text'
    Only returns non-empty data if at least one known label was found.
    """
    if not html_text:
        return {}

    _require_bs4()

    # Parse with lxml if available; fallback to built-in parser otherwise.
    try:
        soup = BeautifulSoup(html_text, 'lxml')
    except Exception:
        soup = BeautifulSoup(html_text, 'html.parser')

    pairs = []

    # 1) Tables: <tr><th>Label</th><td>Value</td></tr> (or <td>/<td>)
    for tr in soup.find_all('tr'):
        th = tr.find('th')
        tds = tr.find_all('td')
        if th and tds:
            label = th.get_text(' ', strip=True)
            value = tds[0].get_text(' ', strip=True)
            if label and value:
                pairs.append((label, value))
            continue
        # Fallback: two <td>s (label/value)
        if len(tds) >= 2:
            label = tds[0].get_text(' ', strip=True)
            value = tds[1].get_text(' ', strip=True)
            if label and value:
                pairs.append((label, value))

    # 2) Definition lists: <dt>Label</dt><dd>Value</dd>
    for dt in soup.find_all('dt'):
        dd = dt.find_next_sibling('dd')
        if not dd:
            continue
        label = dt.get_text(' ', strip=True)
        value = dd.get_text(' ', strip=True)
        if label and value:
            pairs.append((label, value))

    # Build normalized label → list of values
    norm = {}
    for raw_label, raw_value in pairs:
        nl = _normalize_label(raw_label)
        if not nl:
            continue
        norm.setdefault(nl, []).append(raw_value)

    # Identify if the page contains at least one known label
    canonical_hits = []
    for nl in norm.keys():
        if nl in KNOWN_LABEL_SYNONYMS:
            canonical_hits.append(KNOWN_LABEL_SYNONYMS[nl])
    if not canonical_hits:
        return {}

    out = {}

    # Pick first matching origin-like label
    for key in ('origin', 'country', 'region', 'location', 'source'):
        vals = norm.get(key)
        if vals:
            out['origin_text'] = vals[0]
            break

    # Pick first matching roast-like label
    for key in ('roast degree', 'roast level', 'roast'):
        vals = norm.get(key)
        if vals:
            out['roast_text'] = vals[0]
            break

    # Quantity-like labels (may appear as a list of options or a single value)
    qty_vals = []
    for key in ('labeled weight', 'bag size', 'weight', 'size'):
        vals = norm.get(key) or []
        qty_vals.extend(vals)
    if qty_vals:
        out['quantity_texts'] = qty_vals

    # Grind/type-like label (Grind, Bean type, etc. — see KNOWN_LABEL_SYNONYMS)
    for nl, vals in norm.items():
        if KNOWN_LABEL_SYNONYMS.get(nl) == 'grind' and vals:
            out['grind_text'] = vals[0]
            break

    return out

