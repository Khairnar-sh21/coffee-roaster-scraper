def _wordpress_collect_sizes_and_grinds(soup, name, desc):
    """
    Collect size and grind option strings from WooCommerce markup.
    Cutbow (and similar) often put bag size only in the product title (e.g. '12oz') while the
    <select> is for grind/brew method only — so we also scan title/description for weight phrases.
    """
    sizes_raw = []
    grinds_raw = []

    for sel in soup.find_all('select'):
        label = ''
        for prev in sel.find_previous_siblings(limit=8):
            if prev.name == 'label':
                label = prev.get_text(' ', strip=True).lower()
                break
        if not label:
            lab = sel.find_parent('td')
            if lab:
                th = lab.find_previous('th')
                if th:
                    label = th.get_text(' ', strip=True).lower()

        opts = []
        for opt in sel.find_all('option'):
            val = (opt.get('value') or opt.get_text() or '').strip()
            if not val or val.lower() in ('choose an option', 'choose', ''):
                continue
            opts.append(val.replace('-', ' ').strip())

        opt_blob = ' '.join(opts).lower()
        lbl = label

        # Size: explicit label or options that look like bag weights (12 oz, 2 lb, 250g)
        if any(x in lbl for x in ('size', 'weight', 'bag', 'ounce', 'oz')):
            sizes_raw.extend(opts)
            continue
        if re.search(r'\d', opt_blob) and re.search(r'\b(oz|lb|lbs|g|gram)\b', opt_blob):
            sizes_raw.extend(opts)
            continue

        # Grind / preparation (Cutbow: "Whole Bean or Ground Coffee?" with brew methods).
        # option_name_is_grind_or_bean_type covers "Grind" and "Bean type" (same as Woo Store API).
        if (
            option_name_is_grind_or_bean_type(lbl)
            or any(x in lbl for x in ('ground', 'whole bean', 'brew', 'prepare'))
        ) or (not re.search(r'\b(oz|lb)\b', opt_blob) and any(
            x in opt_blob for x in ('whole bean', 'espresso', 'french press', 'turkish', 'drip', 'pour')
        )):
            grinds_raw.extend(opts)

    # Table-based attribute rows (some themes use <table> for variations)
    for tr in soup.find_all('tr'):
        th = tr.find('th')
        tds = tr.find_all('td')
        if not th or not tds:
            continue
        lh = th.get_text(' ', strip=True).lower()
        if not any(x in lh for x in ('size', 'weight', 'bag', 'ounce', 'oz')):
            continue
        cell = tds[0]
        s_el = cell.find('select')
        if s_el:
            for opt in s_el.find_all('option'):
                val = (opt.get('value') or opt.get_text() or '').strip()
                if val and val.lower() not in ('choose an option', 'choose', ''):
                    sizes_raw.append(val.replace('-', ' ').strip())

    blob = f'{name} {desc}'
    sizes_raw.extend(_extract_weight_phrases_from_text(blob))

    return sizes_raw, grinds_raw


def parse_wordpress_product_html(url, html_text, roaster_display_name, roaster_airtable_id=None):
    """
    Map a WordPress/WooCommerce product HTML page to the same Airtable record shape as Shopify/Woo JSON.
    Returns None if the page does not look like a product.
    """
    if not html_text:
        return None
    _require_bs4()
    try:
        soup = BeautifulSoup(html_text, 'lxml')
    except Exception:
        soup = BeautifulSoup(html_text, 'html.parser')

    body = soup.find('body')
    body_classes = ' '.join(body.get('class') or []) if body else ''
    if body and 'product' not in body_classes.lower() and not soup.find(class_=re.compile(r'product')):
        # Not clearly a product template
        if not soup.find('meta', attrs={'property': 'og:type', 'content': re.compile('product', re.I)}):
            if not soup.find(class_=re.compile('woocommerce')):
                return None

    name = ''
    og = soup.find('meta', property='og:title')
    if og and og.get('content'):
        name = _html_stdlib.unescape(og['content'].strip())
    if not name:
        h1 = soup.find('h1', class_=re.compile('product_title')) or soup.find('h1')
        if h1:
            name = _html_stdlib.unescape(h1.get_text(' ', strip=True))

    name = _strip_wordpress_seo_title_suffix(name, roaster_display_name)

    desc_chunks = []
    short_el = soup.find('div', class_=re.compile('woocommerce-product-details__short-description'))
    if short_el:
        desc_chunks.append(short_el.get_text(' ', strip=True))
    long_el = soup.select_one('div#tab-description, div.woocommerce-Tabs-panel--description')
    if long_el:
        desc_chunks.append(long_el.get_text(' ', strip=True))
    desc = ' '.join(desc_chunks)

    search_text = (name + ' ' + desc).lower()
    tags_list = []
    for t in soup.select('a[rel="tag"]'):
        tags_list.append(t.get_text(' ', strip=True))

    sizes_raw, grinds_raw = _wordpress_collect_sizes_and_grinds(soup, name, desc)

    final_roast = get_roast_level(search_text)
    final_origins = get_origins(search_text)
    final_quantities = get_quantities(sizes_raw)
    final_types = get_types(grinds_raw)
    if not final_types:
        final_types = ['Whole Bean']

    extracted = extract_structured_fields_from_html(html_text)
    if extracted:
        if final_origins == ['Global'] and extracted.get('origin_text'):
            o2 = get_origins(extracted['origin_text'])
            if o2 and o2 != ['Global']:
                final_origins = o2
        if final_roast is None and extracted.get('roast_text'):
            r2 = get_roast_level(extracted['roast_text'])
            if r2:
                final_roast = r2
        if not final_quantities and extracted.get('quantity_texts'):
            q2 = get_quantities(extracted.get('quantity_texts') or [])
            if q2:
                final_quantities = q2
        if extracted.get('grind_text'):
            t2 = get_types([extracted['grind_text']])
            if t2:
                final_types = sorted(list(set(final_types + t2)))

    product_link = _canonical_product_link(url)
    if roaster_airtable_id:
        roaster_value = [roaster_airtable_id]
    else:
        roaster_value = [roaster_display_name]

    record = {
        'Product Name': name,
        'Roaster': roaster_value,
        'Product Link': product_link,
        'Origin': final_origins,
        'Quantity': final_quantities,
        'Type': final_types,
    }
    if final_roast:
        record['Roast Level'] = final_roast

    og_img = soup.find('meta', property='og:image')
    if og_img and og_img.get('content'):
        src = og_img['content'].strip()
        if src:
            record['Product Image'] = [{'url': src}]

    return record


def get_product_urls_from_squarespace_sitemaps(store_url):
    """
    Collect probable Squarespace product detail URLs from sitemap(s).
    Works for common Squarespace commerce paths like /shop/p/... and /products/...
    """
    base = store_url.rstrip('/')
    index_urls = [f'{base}/sitemap.xml', f'{base}/sitemap_index.xml']
    sitemap_urls = []

    for index_url in index_urls:
        try:
            resp = requests.get(index_url, timeout=10)
        except Exception:
            continue
        if resp.status_code != 200:
            continue

        locs = _loc_urls_from_sitemap_xml(resp.text)
        if locs:
            sitemap_urls.extend(locs)
            continue

        # Some hosts return non-XML text; fallback to raw URL scan.
        for m in re.finditer(r'https?://[^\s<>"\']+', resp.text or ''):
            sitemap_urls.append(m.group(0))

    if not sitemap_urls:
        sitemap_urls = [f'{base}/sitemap.xml']

    out = set()
    skip_substrings = (
        '/cart', '/checkout', '/account', '/login', '/search',
        '/subscribe', '/subscriptions', '/blog', '/about', '/contact',
    )
    product_hints = ('/shop/p/', '/products/', '/product/')

    for sm_url in set(sitemap_urls):
        if not str(sm_url).startswith('http'):
            continue
        try:
            r = requests.get(sm_url, timeout=10)
        except Exception:
            continue
        if r.status_code != 200:
            continue

        locs = _loc_urls_from_sitemap_xml(r.text)
        if not locs:
            locs = [m.group(0) for m in re.finditer(r'https?://[^\s<>"\']+', r.text or '')]

        for loc in locs:
            loc = _sanitize_url_for_parsing(loc)
            if not loc.startswith('http'):
                continue
            path = _safe_url_path_lower(loc)
            if not path:
                continue
            if any(s in path for s in skip_substrings):
                continue
            if any(h in path for h in product_hints):
                out.add(_canonical_product_link(loc))

    return list(out)


def _squarespace_collect_category_text(soup):
    """
    Best-effort category/tag text from Squarespace product pages.
    """
    parts = []
    for sel in (
        '.ProductItem-nav-breadcrumb a',
        '.breadcrumb a',
        '[data-test*="breadcrumb"] a',
        'a[href*="/shop?category"]',
        'a[href*="/category/"]',
        'a[href*="/tag/"]',
    ):
        for elem in soup.select(sel):
            t = elem.get_text(' ', strip=True)
            if t:
                parts.append(t)
    return ' '.join(parts).lower()


def squarespace_product_passes_filters(name, html_text, category_text=''):
    """
    Same policy intent as Shopify/Woo:
    - reject title/category exclusions
    - include on strong coffee signals (category/type keywords, origins, grind/bean options)
    """
    if not name:
        return False
    title_lower = (name or '').lower()
    if any(_keyword_as_word_in_text(title_lower, kw) for kw in EXCLUSION_TITLE_KEYWORDS):
        return False

    cat_lower = (category_text or '').lower()
    # For category exclusions, avoid full-page HTML (menus/footers can mention gift cards/merch).
    exclusion_blob = (title_lower + ' ' + cat_lower)
    if any(_keyword_as_word_in_text(exclusion_blob, kw) for kw in EXCLUSION_CATEGORY_KEYWORDS):
        return False

    # Build product-focused text only (name + product detail regions), not entire page chrome.
    search_parts = [name or '']
    _require_bs4()
    try:
        soup = BeautifulSoup(html_text or '', 'lxml')
    except Exception:
        soup = BeautifulSoup(html_text or '', 'html.parser')
    for sel in (
        'h1',
        '.ProductItem-details-excerpt',
        '.product-description',
        '[data-test="product-description"]',
        '.ProductItem-details',
    ):
        for el in soup.select(sel):
            t = el.get_text(' ', strip=True)
            if t:
                search_parts.append(t)
    search = ' '.join(search_parts).lower()

    if any(kw in cat_lower for kw in PRODUCT_TYPE_KEYWORDS):
        return True
    # Exclude "Global" so CSS/JS "global" doesn't trigger inclusion.
    if any(o.lower() in search for o in ORIGINS_LIST if o.lower() != 'global'):
        return True

    # Strong bean/grind signal from variants/options.
    if re.search(r'\b(bean type|grind)\b', search):
        if re.search(r'\b(whole bean|ground|drip|french press|espresso)\b', search):
            return True

    # Keep coffee-like pages with specific coffee terms.
    if any(k in search for k in ('single origin', 'espresso blend', 'coffee blend', 'filter blend')):
        return True
    return False


def _squarespace_collect_sizes_and_grinds(soup):
    """
    Collect size and grind options from common Squarespace selectors and option labels.
    """
    sizes_raw = []
    grinds_raw = []

    # 1) <select> based variants
    for sel in soup.find_all('select'):
        label = ''
        sel_id = sel.get('id') or ''
        if sel_id:
            lab = soup.find('label', attrs={'for': sel_id})
            if lab:
                label = lab.get_text(' ', strip=True).lower()
        if not label:
            prev_label = sel.find_previous('label')
            if prev_label:
                label = prev_label.get_text(' ', strip=True).lower()

        opts = []
        for opt in sel.find_all('option'):
            val = (opt.get('value') or opt.get_text() or '').strip()
            if not val or val.lower() in ('select size', 'select grind', 'select', 'choose an option'):
                continue
            opts.append(val.replace('-', ' ').strip())

        opt_blob = ' '.join(opts).lower()
        if any(x in label for x in ('size', 'weight', 'bag', 'ounce', 'oz')):
            sizes_raw.extend(opts)
            continue
        if re.search(r'\d', opt_blob) and re.search(r'\b(oz|lb|lbs|g|gram)\b', opt_blob):
            sizes_raw.extend(opts)
            continue
        if option_name_is_grind_or_bean_type(label) or any(x in label for x in ('ground', 'whole bean')):
            grinds_raw.extend(opts)
            continue
        if any(x in opt_blob for x in ('whole bean', 'ground', 'drip', 'french press', 'espresso')):
            grinds_raw.extend(opts)

    # 2) Generic text fallback from page content
    text = soup.get_text(' ', strip=True).lower()
    for m in re.finditer(r'\b\d+(?:\.\d+)?\s*(?:oz|ounce|ounces|lb|lbs|pound|pounds|g|gram|grams)\b', text):
        sizes_raw.append(m.group(0))
    if re.search(r'\bwhole bean\b', text):
        grinds_raw.append('Whole Bean')
    if re.search(r'\b(ground|drip|french press|espresso)\b', text):
        grinds_raw.append('Ground')

    return sizes_raw, grinds_raw


def squarespace_product_to_record(url, html_text, roaster_display_name, roaster_airtable_id=None):
    """
    Parse a Squarespace product page into the shared Airtable record shape.
    """
    if not html_text:
        return None
    _require_bs4()
    try:
        soup = BeautifulSoup(html_text, 'lxml')
    except Exception:
        soup = BeautifulSoup(html_text, 'html.parser')

    title = ''
    og = soup.find('meta', property='og:title')
    if og and og.get('content'):
        title = _html_stdlib.unescape(og.get('content', '').strip())
    if not title:
        h1 = soup.find('h1')
        if h1:
            title = _html_stdlib.unescape(h1.get_text(' ', strip=True))
    if not title:
        return None
    # Some Squarespace pages include "Product — Roaster Name" in og:title.
    title = _strip_wordpress_seo_title_suffix(title, roaster_display_name)

    desc = ''
    md = soup.find('meta', attrs={'name': 'description'})
    if md and md.get('content'):
        desc = _html_stdlib.unescape(md.get('content', '').strip())
    if not desc:
        # Product description region fallback
        for sel in (
            '.ProductItem-details-excerpt',
            '.product-description',
            '[data-test="product-description"]',
        ):
            el = soup.select_one(sel)
            if el:
                desc = _html_stdlib.unescape(el.get_text(' ', strip=True))
                break

    sizes_raw, grinds_raw = _squarespace_collect_sizes_and_grinds(soup)
    search_text = f'{title} {desc} {(html_text or "")[:25000]}'

    final_origins = get_origins(search_text)
    final_roast = get_roast_level(search_text)
    final_quantities = get_quantities(sizes_raw)
    final_types = get_types(grinds_raw)
    if not final_types:
        final_types = ['Whole Bean']

    extracted = extract_structured_fields_from_html(html_text)
    if extracted:
        if final_origins == ['Global'] and extracted.get('origin_text'):
            o2 = get_origins(extracted['origin_text'])
            if o2 and o2 != ['Global']:
                final_origins = o2
        if final_roast is None and extracted.get('roast_text'):
            r2 = get_roast_level(extracted['roast_text'])
            if r2:
                final_roast = r2
        if not final_quantities and extracted.get('quantity_texts'):
            q2 = get_quantities(extracted.get('quantity_texts') or [])
            if q2:
                final_quantities = q2
        if extracted.get('grind_text'):
            t2 = get_types([extracted['grind_text']])
            if t2:
                final_types = sorted(list(set(final_types + t2)))

    if roaster_airtable_id:
        roaster_value = [roaster_airtable_id]
    else:
        roaster_value = [roaster_display_name]

    record = {
        'Product Name': title,
        'Roaster': roaster_value,
        'Product Link': _canonical_product_link(url),
        'Origin': final_origins,
        'Quantity': final_quantities,
        'Type': final_types,
    }
    if final_roast:
        record['Roast Level'] = final_roast

    og_img = soup.find('meta', property='og:image')
    if og_img and og_img.get('content'):
        src = og_img.get('content', '').strip()
        if src:
            record['Product Image'] = [{'url': src}]

    return record


