def _canonical_roaster_host(store_url):
    """
    Normalize website host for matching roasters (e.g. www vs non-www).
    Used so WordPress trace detection matches Airtable URL to the same site.
    """
    if not store_url:
        return ''
    u = str(store_url).strip().rstrip('/')
    if not u.startswith('http'):
        u = 'https://' + u
    try:
        p = urlparse(u)
        host = (p.netloc or '').lower()
        if host.startswith('www.'):
            host = host[4:]
        return host
    except Exception:
        return ''


def _sanitize_url_for_parsing(url):
    """
    Sanitize raw URL strings extracted from sitemaps/regex scans.

    Some hosts/sitemap formats include stray characters (e.g. a trailing ']' from
    regex matches). Those can make urlparse raise ValueError (e.g. invalid IPv6).
    """
    if url is None:
        return ''
    s = str(url).strip()
    if not s:
        return ''
    # Trim common stray trailing delimiters that appear in sitemap/regex text.
    s = s.rstrip(']}>).,;')
    s = s.rstrip('([')
    return s


def _safe_url_path_lower(url):
    """
    urlparse wrapper that never throws; returns '' on failure.
    """
    s = _sanitize_url_for_parsing(url)
    if not s:
        return ''
    try:
        return urlparse(s).path.lower()
    except ValueError:
        return ''


def _normalize_store_base_url(store_url):
    """
    Normalize roaster base URLs from Airtable so scraper endpoint composition stays valid.

    - Removes query params/fragments (e.g. ?srsltid=..., #section)
    - Preserves scheme + host (+ subpath if intentionally present)
    - Trims trailing slash
    """
    s = _sanitize_url_for_parsing(store_url)
    if not s:
        return ''
    if not s.startswith(('http://', 'https://')):
        s = 'https://' + s
    try:
        p = urlparse(s)
    except ValueError:
        return ''
    if not p.netloc:
        return ''
    path = (p.path or '').rstrip('/')
    if path == '/':
        path = ''
    normalized = urlunparse((p.scheme or 'https', p.netloc, path, '', '', ''))
    return normalized.rstrip('/')
