# 4. VENDOR → ROASTER (CLOSE MATCH)
# ==========================================
def _normalize_for_match(s):
    """Lowercase, strip, remove common company suffixes for comparison."""
    if not s:
        return ''
    s = s.lower().strip()
    for suffix in [' co.', ' co', ' llc', ' inc.', ' inc', ' company', ' co']:
        if s.endswith(suffix):
            s = s[:-len(suffix)].strip()
    return s


def vendor_matches_roaster(shopify_vendor, roaster_display_name):
    """True if Shopify vendor is a close match to the roaster name from Airtable."""
    if not shopify_vendor or not roaster_display_name:
        return False
    v = _normalize_for_match(shopify_vendor)
    r = _normalize_for_match(roaster_display_name)
    if not v or not r:
        return False
    return r in v or v in r or v == r


def get_roaster_display(shopify_vendor, roaster_display_name):
    """If vendor is a close match to roaster name, return roaster name; else cleaned vendor."""
    if not shopify_vendor:
        return roaster_display_name or 'Unknown Roaster'
    if vendor_matches_roaster(shopify_vendor, roaster_display_name):
        return roaster_display_name
    # Fallback: strip common suffixes from vendor
    cleaned = shopify_vendor.strip()
    for suffix in [' Co.', ' LLC', ' Inc.', ' Company']:
        if cleaned.endswith(suffix):
            cleaned = cleaned[:-len(suffix)].strip()
            break
    return cleaned or roaster_display_name


def roaster_display_matches(airtable_roaster_value, current_roaster_name):
    """True if the Roaster value stored in Airtable matches this run's roaster (for safe delete)."""
    if not current_roaster_name:
        return False
    text = ''
    if isinstance(airtable_roaster_value, list):
        text = ' '.join(str(v) for v in airtable_roaster_value)
    elif airtable_roaster_value is not None:
        text = str(airtable_roaster_value)
    return vendor_matches_roaster(text, current_roaster_name)


