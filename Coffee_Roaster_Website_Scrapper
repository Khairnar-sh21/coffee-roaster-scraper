def _loc_urls_from_sitemap_xml(xml_text):
    urls = []
    try:
        root = ET.fromstring(xml_text)
    except ET.ParseError:
        return urls
    for elem in root.iter():
        tag = elem.tag.split('}')[-1] if '}' in elem.tag else elem.tag
        if tag == 'loc' and elem.text:
            urls.append(elem.text.strip())
    return urls


def _handle_from_product_url(url):
    if '/products/' not in url:
        return None
    part = url.split('/products/')[-1]
    handle = part.split('/')[0].split('?')[0].strip()
    handle = _sanitize_url_for_parsing(handle)
    return handle if handle else None


def get_all_product_handles_from_sitemap(store_url):
    base = store_url.rstrip('/')
    resp = requests.get(f'{base}/sitemap.xml')
    if resp.status_code != 200:
        return []
    product_sitemap_urls = [loc for loc in _loc_urls_from_sitemap_xml(resp.text) if 'sitemap_products' in loc]
    handles = set()
    for sm_url in product_sitemap_urls:
        r = requests.get(sm_url)
        if r.status_code != 200:
            continue
        for loc in _loc_urls_from_sitemap_xml(r.text):
            h = _handle_from_product_url(loc)
            if h:
                handles.add(h)
    return list(handles)


def _shopify_breadcrumb_text(html_text):
    """
    Extract breadcrumb-ish text from Shopify pages so we can infer the product's
    collection/category (e.g. "Home / Collections / SUBSCRIPTIONS / ...").
    """
    if not html_text:
        return ''
    _require_bs4()
    try:
        soup = BeautifulSoup(html_text, 'lxml')
    except Exception:
        soup = BeautifulSoup(html_text, 'html.parser')

    # Try common breadcrumb containers first (avoid picking up header nav).
    cand = []
    for sel in (
        'nav[aria-label*="breadcrumb"]',
        '[class*="breadcrumb"]',
        '[aria-label*="breadcrumb"]',
    ):
        for el in soup.select(sel):
            t = el.get_text(' ', strip=True)
            if t:
                cand.append(t)
    if cand:
        # Prefer the longest match; it often contains "Home / Collections / ..."
        return max(cand, key=len)

    # Fallback: use full page text but later we match against "collections ... subscriptions/sample".
    return soup.get_text(' ', strip=True)[:20000]


def shopify_product_in_excluded_collection(html_text):
    """
    Return True if the product page UI indicates it's under excluded collections:
      - Subscriptions
      - Samples (including "Sample Sizes", "Samples", etc.)

    When breadcrumb says a generic "All"/coffee collection, we don't exclude here;
    title-based exclusions remain the source of truth.
    """
    if not html_text:
        return False

    _require_bs4()
    try:
        soup = BeautifulSoup(html_text, 'lxml')
    except Exception:
        soup = BeautifulSoup(html_text, 'html.parser')

    bc = ''
    # Prefer breadcrumb containers when present; else fall back to a small slice of page text.
    try:
        bc = (_shopify_breadcrumb_text(html_text) or '').lower()
    except Exception:
        bc = soup.get_text(' ', strip=True)[:20000].lower()

    # 1) Breadcrumb-based exclusion (when Shopify includes collection context in breadcrumbs)
    if re.search(r'collections[^a-z0-9]{0,25}subscriptions', bc):
        return True
    if re.search(r'collections[^a-z0-9]{0,25}samples?', bc):
        return True

    # 2) Subscription widget exclusion:
    # Recharge subscription products often show "Delivery every ..." on the page UI.
    lower = (html_text or '').lower()
    if 'delivery every' in lower and ('recharge subscription' in lower or 'recharge subscriptions' in lower):
        return True

    # 3) Sample/taster exclusion:
    # Shopify nav menus often contain "Samples" even for regular products, so we must rely on
    # product meta / title markers (e.g., og:description contains "sample size",
    # and the HTML <title> contains "... Sample: ...").
    ogd = soup.find('meta', property='og:description')
    og_description = ogd.get('content', '') if ogd else ''
    name_desc = soup.find('meta', attrs={'name': 'description'})
    name_description = name_desc.get('content', '') if name_desc else ''
    title_tag = ''
    t = soup.find('title')
    if t:
        title_tag = t.get_text(' ', strip=True)

    sample_blob = f'{og_description} {name_description} {title_tag}'.lower()
    if (
        'sample size' in sample_blob
        or 'sample:' in sample_blob
        or 'stone dry sample' in sample_blob
        or 'taster' in sample_blob
    ):
        return True

    return False


def shopify_product_is_subscription_only(product, html_text=''):
    """
    Conservative subscription-only detector for Shopify products.

    Important behavior:
    - We exclude only when product-specific signals are strong.
    - "Subscribe & save" on normal coffee products should not be excluded unless the
      SKU itself is clearly a subscription listing.
    """
    if not isinstance(product, dict):
        return False

    title = str(product.get('title') or '').strip().lower()
    handle = str(product.get('handle') or '').strip().lower()
    ptype = _normalize_product_type(product.get('product_type'))

    # 1) Product-level Shopify metadata signal (when available on some stores).
    selling_plan_groups = product.get('selling_plan_groups')
    if isinstance(selling_plan_groups, list) and selling_plan_groups:
        variants = product.get('variants') or []
        # If every variant requires a selling plan, this is subscription-only.
        # Mixed one-time + subscription products should not be excluded here.
        requires_flags = [
            bool(v.get('requires_selling_plan'))
            for v in variants
            if isinstance(v, dict) and v.get('requires_selling_plan') is not None
        ]
        if requires_flags and all(requires_flags):
            return True

    # 2) Strong handle/title/product_type signals for dedicated subscription SKUs.
    strong_subscription_keywords = [
        'subscription',
        'subscribe',
        'recurring',
        'auto-ship',
        'autoship',
        'roasters-choice',
    ]
    if any(_keyword_as_word_in_text(handle, kw) for kw in strong_subscription_keywords):
        return True
    if any(_keyword_as_word_in_text(title, kw) for kw in strong_subscription_keywords):
        return True
    if _keyword_as_word_in_text(ptype, 'subscription'):
        return True

    # 3) Product-page buy-widget signal (only when one-time purchase is not present).
    # This keeps mixed purchase-mode products from being excluded.
    lower = str(html_text or '').lower()
    if lower:
        has_subscription_widget = (
            ('delivery every' in lower)
            and (
                'recharge subscription' in lower
                or 'recharge subscriptions' in lower
                or 'name="selling_plan"' in lower
                or "name='selling_plan'" in lower
            )
        )
        has_one_time_marker = (
            'one time' in lower
            or
            'one-time purchase' in lower
            or 'one time purchase' in lower
            or 'purchase options' in lower
        )
        if has_subscription_widget and not has_one_time_marker:
            return True

    return False


def shopify_product_passes_empty_type_fallback(product):
    """
    SECOND CHANCE when Shopify's product_type is blank or doesn't say coffee/blend/origin.

    Why this exists
    ---------------
    Some stores leave product_type empty on real coffee SKUs. The old rule was: skip anything
    without product_type keywords — so products like "Burundi" or "Guatemala" never made it in.

    What we do instead (same *idea* as WooCommerce's woo_product_passes_filters)
    -----------------------------------------------------------------------------
    We do NOT re-check EXCLUSION_TITLE_KEYWORDS here; the main loop still applies those right
    after this gate (so "Coffee Mug" still drops via the title list).

    1) Tags ≈ Woo "categories" for merch: if tags look like gift cards / gear / apparel,
       we reject (EXCLUSION_CATEGORY_KEYWORDS).

    2) Otherwise we KEEP the product only if we can find strong coffee signals:
       - Bean/grind-type options on the Shopify product (e.g. option named "Grind" or
         "Bean type" with values like "Whole Bean" / "Ground")
       - OR: tags contain PRODUCT_TYPE_KEYWORDS (e.g. "coffee", "blend", "origin")
       - OR: Any country/region from ORIGINS_LIST appears in the product text

       We intentionally do *not* keep items just because their description mentions
       the word "coffee" (many accessories and gifts include that word).

    Examples
    --------
    - product_type "", title "Burundi Natural" → ORIGINS_LIST match → KEEP (then title filter).
    - product_type "", tags "Gift Cards" → category exclusion → SKIP.
    - product_type "", title "Random Candle", no signals → SKIP.
    """
    title = _html_stdlib.unescape(product.get('title') or '').strip()
    body = _html_stdlib.unescape(product.get('body_html') or '')
    vendor = (product.get('vendor') or '').strip()
    tags_raw = product.get('tags')
    if isinstance(tags_raw, list):
        tags_str = ', '.join(str(t) for t in tags_raw)
    else:
        tags_str = str(tags_raw or '')
    tags_lower = tags_str.lower()

    search_all = (title + ' ' + body + ' ' + tags_str + ' ' + vendor).lower()
    title_lower = title.lower()
    body_lower = body.lower()

    # Merch / gift-card exclusion (same intent as Woo category exclusions).
    # We check broader than just tags because some Shopify products label these
    # keywords in the title/description, not the "tags" field.
    if any(_keyword_as_word_in_text(search_all, kw) for kw in EXCLUSION_CATEGORY_KEYWORDS):
        return False

    # Option A (safe tweak): if the title looks like a coffee SKU (Blend/Espresso),
    # require a real "coffee" word somewhere in the visible text.
    # This is specifically to recover stores that use empty product_type and/or
    # non-standard tag vocab (e.g. Elixir "Weekender Blend", "Treehouse Blend").
    if (
        any(_keyword_as_word_in_text(title_lower, kw) for kw in ['blend', 'espresso'])
        and _keyword_as_word_in_text(title_lower + ' ' + body_lower, 'coffee')
    ):
        return True

    # 1) Strongest signal: explicit bean/grind option exists on the product.
    for opt in product.get('options') or []:
        opt_name = (opt.get('name') or '').lower()
        if option_name_is_grind_or_bean_type(opt_name):
            opt_values = opt.get('values') or []
            if get_types(opt_values):
                return True

    # 2) Explicit tag-based signals.
    if any(_keyword_as_word_in_text(tags_lower, kw) for kw in PRODUCT_TYPE_KEYWORDS):
        return True

    # 3) Origin signals inside the product text.
    # Exclude "Global" so random CSS/JS text containing "global" doesn't trigger inclusion.
    if any(o.lower() in search_all for o in ORIGINS_LIST if o.lower() != 'global'):
        return True

    return False


def shopify_product_passes_wholesale_tag_rules(product):
    """
    Shopify tag gate requested by user:
    - If tags are exactly {'coffee', 'wholesale'} -> exclude
    - If tags are exactly {'coffee', 'intinew', 'wholesale'} -> exclude
    - If tags are exactly {'wholesale'} -> exclude
    - If tag 'grocery' is present (alone or with any other tags) -> exclude
    - If there is exactly one tag and it is a 4-digit year (e.g. 2022) -> exclude
    - If tags are empty -> include
    - If tags include {'coffee', 'wholesale'} plus any extra tag(s) -> include
    - Any other tag combination -> include
    """
    tags_raw = product.get('tags')
    if isinstance(tags_raw, list):
        raw_items = [str(t).strip().lower() for t in tags_raw if str(t).strip()]
    else:
        tags_text = str(tags_raw or '')
        raw_items = [t.strip().lower() for t in tags_text.split(',') if t.strip()]

    tags_set = set(raw_items)
    if not tags_set:
        return True

    if 'grocery' in tags_set:
        return False

    if tags_set == {'wholesale'}:
        return False

    if tags_set == {'coffee', 'wholesale'}:
        return False

    if tags_set == {'coffee', 'intinew', 'wholesale'}:
        return False

    if len(tags_set) == 1:
        only_tag = next(iter(tags_set))
        if re.fullmatch(r'(19|20)\d{2}', only_tag):
            return False

    return True


def get_shopify_collection_handles(store_url, collection_handle):
    """
    Return all product handles currently listed in a Shopify collection feed.

    Why this exists:
    - Some stores keep old products accessible via direct product URLs but hide them
      from the storefront by removing them from active collections.
    - Useful when you want to mirror what a storefront collection currently lists.

    Returns
    -------
    set[str] | None
        - set of handles on success (can be empty)
        - None when the collection feed cannot be fetched/parsed, so caller can
          safely fall back to existing scraper logic.
    """
    base = store_url.rstrip('/')
    handle = str(collection_handle or '').strip().strip('/')
    if not base or not handle:
        return None

    handles = set()
    try:
        for page in range(1, 21):
            resp = requests.get(
                f'{base}/collections/{handle}/products.json',
                params={'limit': 250, 'page': page},
                timeout=15,
            )
            if resp.status_code != 200:
                return None
            payload = resp.json()
            products = payload.get('products', []) if isinstance(payload, dict) else []
            if not products:
                break
            for p in products:
                h = str((p or {}).get('handle') or '').strip()
                if h:
                    handles.add(h)
            if len(products) < 250:
                break
    except Exception:
        return None

    return handles


def get_all_coffee_products_for_store(store_url, roaster_name=None, roaster_airtable_id=None):
    """
    Discover products via sitemap, fetch JSON, keep coffee-like products, then apply exclusions.

    Parameters
    ----------
    roaster_name : str, optional
        Reserved for logging / future use; roaster-specific rules use `roaster_airtable_id`.

    roaster_airtable_id : str, optional
        Roaster record id from Airtable (used when linking scraped products to roasters).

    Filtering order (Shopify)
    -------------------------
    1) Exclude explicit Shopify product types:
       - hawaiian coffee club
       - espresso bites
       - coffee & tea sets
       - tea
       - merch / merchandise
       - tee / tees / t-shirt

    2) product_type must contain coffee / blend / origin — OR if it doesn't, we run
       shopify_product_passes_empty_type_fallback() (Woo-style signals from tags + text).

    3) shopify_product_passes_wholesale_tag_rules() (global tag exclusions).

    4) EXCLUSION_TITLE_KEYWORDS on the title (subscriptions, mugs, bundles, etc.).

    5) shopify_product_is_subscription_only() on product metadata / page buy widget.

    6) shopify_product_in_excluded_collection() on the live product page (subscriptions /
       samples in breadcrumb or UI), but only for products kept via empty-type fallback.

    See shopify_product_passes_empty_type_fallback.__doc__ for the fallback rules and examples.
    """
    handles = get_all_product_handles_from_sitemap(store_url)
    coffee_products = []
    for handle in handles:
        url = f'{store_url}/products/{handle}.json'
        resp = requests.get(url)
        if resp.status_code != 200:
            continue
        product = resp.json().get('product', {})
        if not product:
            continue
        ptype_normalized = _normalize_product_type(product.get('product_type'))
        if ptype_normalized in EXCLUDED_SHOPIFY_PRODUCT_TYPES:
            continue
        ptype = (product.get('product_type') or '').lower()
        ptype_ok = any(kw in ptype for kw in PRODUCT_TYPE_KEYWORDS)
        kept_by_fallback = False
        if not ptype_ok and not shopify_product_passes_empty_type_fallback(product):
            continue
        if not ptype_ok:
            kept_by_fallback = True
        if not shopify_product_passes_wholesale_tag_rules(product):
            continue
        title = (product.get('title') or '').lower()
        if any(_keyword_as_word_in_text(title, kw) for kw in EXCLUSION_TITLE_KEYWORDS):
            continue

        product_page_url = f'{store_url}/products/{handle}'
        html_text = fetch_page_html(product_page_url)
        if shopify_product_is_subscription_only(product, html_text):
            continue

        # Option A: run collection/category UI heuristic only for products that were
        # kept by empty-type fallback. Products that already pass explicit product_type
        # checks skip this noisy UI gate to avoid false exclusions.
        if kept_by_fallback and html_text and shopify_product_in_excluded_collection(html_text):
            continue

        coffee_products.append(product)
    return coffee_products


