# 6. PLATFORM DETECTION
# ==========================================
def detect_platform(store_url):
    """
    Best-effort detection of whether a store is Shopify, WooCommerce, or Squarespace.
    Returns: 'shopify', 'woocommerce', 'squarespace', or 'unknown'.
    """
    base = store_url.rstrip('/')
    try:
        resp = requests.get(base, timeout=10)
    except Exception:
        return 'unknown'

    text = (resp.text or '').lower()
    headers_low = {k.lower(): str(v).lower() for k, v in resp.headers.items()}

    # Shopify indicators
    if 'cdn.shopify.com' in text or 'shopify.theme' in text:
        return 'shopify'
    if 'x-shopify-stage' in headers_low or 'x-shopify-shop-domain' in headers_low:
        return 'shopify'

    # WooCommerce indicators in HTML
    if 'wp-content/plugins/woocommerce' in text or 'woocommerce' in text and 'wp-content' in text:
        return 'woocommerce'
    if '/wp-json/wc/' in text:
        return 'woocommerce'

    # WooCommerce Store API probe
    try:
        api_resp = requests.get(f'{base}/wp-json/wc/store/v1/products', params={'per_page': 1}, timeout=5)
        if api_resp.status_code == 200:
            return 'woocommerce'
    except Exception:
        pass

    # Shopify sitemap probe
    try:
        sm_resp = requests.get(f'{base}/sitemap.xml', timeout=5)
        if sm_resp.status_code == 200 and 'sitemap_products' in sm_resp.text:
            return 'shopify'
    except Exception:
        pass

    # Squarespace indicators in HTML/headers/sitemap
    if 'static1.squarespace.com' in text or 'squarespace.com' in text:
        return 'squarespace'
    if 'x-sqsp-edge' in headers_low or 'x-squarespace-request-id' in headers_low:
        return 'squarespace'
    if 'meta name="generator"' in text and 'squarespace' in text:
        return 'squarespace'
    try:
        sm_resp = requests.get(f'{base}/sitemap.xml', timeout=5)
        sm_txt = (sm_resp.text or '').lower()
        if sm_resp.status_code == 200 and ('/shop/p/' in sm_txt or 'squarespace.com' in sm_txt):
            return 'squarespace'
    except Exception:
        pass

    return 'unknown'


def is_wordpress_site(store_url):
    """
    Lightweight check for WordPress, independent of Shopify/Woo detection.
    Used to optionally also run WordPress-style scrapers when appropriate.
    """
    base = store_url.rstrip('/')

    # 1) Home page HTML/header indicators
    try:
        resp = requests.get(base, timeout=10, allow_redirects=True)
        text = (resp.text or '').lower()
        headers_low = {k.lower(): str(v).lower() for k, v in resp.headers.items()}
    except Exception:
        text = ''
        headers_low = {}

    if 'wp-content/' in text or 'wp-includes/' in text:
        return True
    if 'meta name="generator"' in text and 'wordpress' in text:
        return True
    if 'rel="https://api.w.org/' in text or 'api.w.org' in text:
        return True
    if 'x-pingback' in headers_low and 'xmlrpc.php' in headers_low.get('x-pingback', ''):
        return True

    # 2) Endpoint probes (more robust for sites hiding WP markers on homepage)
    probes = [
        ('/wp-json/', lambda r: r.status_code == 200 and ('name' in (r.text or '').lower() or 'routes' in (r.text or '').lower())),
        ('/wp-login.php', lambda r: r.status_code in (200, 403) and 'wp-login' in (r.text or '').lower()),
        ('/xmlrpc.php', lambda r: r.status_code in (200, 405, 403) and ('xml-rpc' in (r.text or '').lower() or 'xmlrpc' in (r.text or '').lower())),
        ('/wp-content/', lambda r: r.status_code in (200, 301, 302, 403)),
        ('/wp-includes/', lambda r: r.status_code in (200, 301, 302, 403)),
    ]
    hits = 0
    for path, is_hit in probes:
        try:
            r = requests.get(f'{base}{path}', timeout=6, allow_redirects=True)
            if is_hit(r):
                hits += 1
        except Exception:
            continue

    # Require at least one positive probe; stronger confidence if 2+.
    return hits >= 1


