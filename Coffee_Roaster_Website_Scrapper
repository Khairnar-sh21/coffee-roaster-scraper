def get_roasters_from_airtable():
    """Read roaster name and base URL from the roasters config table.
    Only include rows where Web Scrapping == 'Yes'.
    Returns a list of dicts: [{"id": "...", "name": "...", "base_url": "..."}]
    """
    roasters = []
    for rec in roasters_table.all():
        fields = rec.get('fields', {})
        name = fields.get(ROASTER_NAME_FIELD) or fields.get('Name')
        url = fields.get(BASE_URL_FIELD) or fields.get('Store URL')
        web_scrap_val = fields.get(WEB_SCRAPING_FIELD)
        # Support single select / text where the label is 'Yes'
        if isinstance(web_scrap_val, dict):
            web_scrap_label = (web_scrap_val.get('name') or '').strip()
        else:
            web_scrap_label = str(web_scrap_val or '').strip()

        platform_val = fields.get(PLATFORM_USED_FIELD)
        # Support single select / text where the label is 'Shopify' or 'Woocommerce'
        if isinstance(platform_val, dict):
            platform_label = (platform_val.get('name') or '').strip()
        else:
            platform_label = str(platform_val or '').strip()

        normalized_url = _normalize_store_base_url(url)
        if name and normalized_url and web_scrap_label.lower() == 'yes':
            roasters.append({
                'id': rec.get('id'),
                'name': str(name).strip(),
                'base_url': normalized_url,
                'platform_used': platform_label,
            })
    return roasters


