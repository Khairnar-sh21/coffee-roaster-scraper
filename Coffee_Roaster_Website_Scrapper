# 2. GENERIC HTML LABEL→VALUE PARSER (failsafe)
# ==========================================
# This parser is platform-agnostic: it can be used for Shopify, WooCommerce,
# and other platforms (e.g. Squarespace) as long as the product page contains
# structured label/value blocks like tables (<th>/<td>) or definition lists (<dt>/<dd>).
#
# Important safety rule:
# - We only use extracted values if we find at least ONE "known label" on the page,
#   to reduce the risk of pulling unrelated tables (shipping, footer, etc.).

KNOWN_LABEL_SYNONYMS = {
    # Origin
    'origin': 'origin',
    'country': 'origin',
    'region': 'origin',
    'location': 'origin',
    'source': 'origin',
    # Roast
    'roast': 'roast',
    'roast level': 'roast',
    'roast degree': 'roast',
    # Quantity / size
    'weight': 'quantity',
    'size': 'quantity',
    'bag size': 'quantity',
    'labeled weight': 'quantity',
    # Grind / type (many Shopify themes use "Bean type" instead of "Grind")
    'grind': 'grind',
    'bean type': 'grind',
    'beantype': 'grind',
}


def _normalize_label(label):
    if not label:
        return ''
    s = _html_stdlib.unescape(str(label)).lower()
    s = re.sub(r'[\s\u00A0]+', ' ', s)          # collapse whitespace
    s = re.sub(r'[^a-z0-9 ]+', '', s).strip()   # remove punctuation
    return s


def _keyword_as_word_in_text(text, keyword):
    """
    True if keyword appears as a standalone word/phrase in text.
    Prevents false positives like 'greencoffee' matching 'coffee'.
    """
    if not text or not keyword:
        return False
    t = str(text).lower()
    k = str(keyword).lower().strip()
    if not k:
        return False
    # Treat any non-alphanumeric boundary as a separator.
    pat = re.compile(r'(^|[^a-z0-9])' + re.escape(k) + r'([^a-z0-9]|$)', re.I)
    return bool(pat.search(t))


def _normalize_product_type(product_type):
    """Normalize product_type for exact matching."""
    s = str(product_type or '').strip().lower()
    return re.sub(r'\s+', ' ', s)


