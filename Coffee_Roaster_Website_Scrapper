        og = soup.find('meta', property='og:title')
        if og and og.get('content'):
            name = _html_stdlib.unescape(og.get('content', '').strip())
        if not name:
            h1 = soup.find('h1')
            if h1:
                name = _html_stdlib.unescape(h1.get_text(' ', strip=True))

        cat_text = _squarespace_collect_category_text(soup)
        if not squarespace_product_passes_filters(name, html_text, cat_text):
            continue

        rec = squarespace_product_to_record(page_url, html_text, roaster_name, roaster_airtable_id)
        if not rec or not rec.get('Product Link'):
            continue

        canonical = _canonical_product_link(rec['Product Link'])
        seen_links.add(canonical)
        entry = existing_by_link.get(canonical)
        existing_id = entry['id'] if entry else None
        try:
            if DRY_RUN:
                if existing_id:
                    print(f'  [DRY_RUN] 🔁 Would update: {rec.get("Product Name")}')
                else:
                    print(f'  [DRY_RUN] ✅ Would add: {rec.get("Product Name")}')
            else:
                if existing_id:
                    products_table.update(existing_id, rec, typecast=True)
                    print(f'  🔁 Updated: {rec.get("Product Name")}')
                else:
                    created = products_table.create(rec, typecast=True)
                    existing_by_link[canonical] = {
                        'id': created['id'],
                        'roaster_text': roaster_name,
                        'roaster_ids': [str(roaster_airtable_id)] if roaster_airtable_id else [],
                    }
                    print(f'  ✅ Added: {rec.get("Product Name")}')
        except Exception as e:
            print(f'  ❌ Failed {rec.get("Product Name")}: {e}')

    delete_obsolete_products_for_roaster(roaster_name, roaster_airtable_id, seen_links, existing_by_link)
    print('\nDone with Squarespace roaster.')


def delete_obsolete_products_for_roaster(roaster_name, roaster_airtable_id, seen_links, existing_by_link):
    """
    Remove product rows for this roaster whose Product Link is not in seen_links.
    existing_by_link: canonical link -> {'id', 'roaster_text', 'roaster_ids'}
    """
    roaster_id = roaster_airtable_id

    def is_this_roaster(meta):
        if roaster_id and roaster_id in meta.get('roaster_ids', []):
            return True
        rt = (meta.get('roaster_text') or '').lower()
        return roaster_name.lower() in rt

    links_to_delete = [
        link for link, meta in existing_by_link.items()
        if is_this_roaster(meta) and link not in seen_links
    ]
    if not links_to_delete:
        return
    print(f'\n  Deleting {len(links_to_delete)} obsolete record(s) for {roaster_name}...')
    if DRY_RUN:
        print(f'  [DRY_RUN] Would delete {len(links_to_delete)} record(s), but DRY_RUN is enabled.')
        return
    ids_to_delete = [existing_by_link[link]['id'] for link in links_to_delete]
    for i in range(0, len(ids_to_delete), 10):
        batch = ids_to_delete[i : i + 10]
        try:
            products_table.batch_delete(batch)
            print(f'  🗑️ Deleted {len(batch)} record(s).')
        except Exception as e:
            print(f'  ❌ Batch delete failed: {e}')


def replace_existing_products_for_roaster(roaster_name, roaster_airtable_id, existing_by_link):
    """
    Delete all current Airtable rows for a roaster before re-adding fresh scrape results.
    Returns the number of matched existing rows.
    """
    roaster_id = str(roaster_airtable_id or '').strip()
    links_to_replace = []
    for link, meta in existing_by_link.items():
        ids = [str(v) for v in (meta.get('roaster_ids') or [])]
        rt = str(meta.get('roaster_text') or meta.get('roaster_display') or '')
        if (roaster_id and roaster_id in ids) or roaster_display_matches(rt, roaster_name):
            links_to_replace.append(link)

    if not links_to_replace:
        return 0

    print(f"  Replacing {len(links_to_replace)} existing record(s) for {roaster_name}...")
    if DRY_RUN:
        print(f'  [DRY_RUN] Would delete {len(links_to_replace)} existing record(s) before re-add.')
    else:
        ids_to_delete = [existing_by_link[link]['id'] for link in links_to_replace]
        for i in range(0, len(ids_to_delete), 10):
            batch = ids_to_delete[i : i + 10]
            try:
                products_table.batch_delete(batch)
                print(f"  🗑️ Deleted {len(batch)} record(s) for replace mode.")
            except Exception as e:
                print(f"  ❌ Replace-mode batch delete failed: {e}")
                for rid in batch:
                    try:
                        products_table.delete(rid)
                        print("  🗑️ Deleted 1 record (replace fallback).")
                    except Exception as e2:
                        msg = str(e2)
                        if 'NOT_FOUND' in msg or '404' in msg:
                            print("  ℹ️ Skip missing record (replace fallback).")
                        else:
                            print(f"  ❌ Replace fallback delete failed: {e2}")
    for link in links_to_replace:
        existing_by_link.pop(link, None)
    return len(links_to_replace)


def fetch_and_push_wordpress_for_roaster(
    roaster_name,
    store_url,
    roaster_airtable_id=None,
    woo_seen_links=None,
    woo_records_by_link=None,
    defer_delete=False,
):
    """
    Generic WordPress/WooCommerce *HTML* product pass: discover URLs from sitemaps, parse each page,
    apply the same inclusion/exclusion rules as Shopify/Woo, upsert to Airtable.

    When woo_seen_links / woo_records_by_link are provided (same roaster after WooCommerce run):
    - WooCommerce is primary; WordPress only fills missing fields on overlapping URLs.
    - WordPress can still discover extra product URLs the Store API missed.

    Returns dict with:
      - 'seen_links': set of canonical URLs to keep for this roaster
      - 'existing_by_link': snapshot used for delete (if defer_delete)
    """
    woo_seen_links = woo_seen_links or set()
    woo_records_by_link = woo_records_by_link or {}

    existing_by_link = {}
    for rec in products_table.all(fields=['Product Link', 'Roaster']):
        fields = rec.get('fields', {})
        link = fields.get('Product Link')
        if not link:
            continue
        canonical = _canonical_product_link(link)
        roaster_val = fields.get('Roaster')
        roaster_text = ''
        roaster_ids = []
        if isinstance(roaster_val, list):
            roaster_ids = [str(v) for v in roaster_val]
            roaster_text = ' '.join(roaster_ids)
        elif roaster_val is not None:
            roaster_text = str(roaster_val)
        existing_by_link[canonical] = {
            'id': rec['id'],
            'roaster_text': roaster_text,
            'roaster_ids': roaster_ids,
        }

    print(f'\n——— {roaster_name} ({store_url}) [WordPress HTML] ———')
    print('Discovering product URLs from sitemaps...')
    urls = get_product_urls_from_wordpress_sitemaps(store_url)
    print(f'Found {len(urls)} product URL(s) in sitemaps. Fetching & filtering...\n')

    # For Woo/Shopify + WordPress combined runs, the primary pass has already upserted
    # canonical rows and may pass them in woo_seen_links. Do not replace in that case.
    if REPLACE_ROASTER_PRODUCTS_EACH_RUN and not woo_seen_links:
        replace_existing_products_for_roaster(roaster_name, roaster_airtable_id, existing_by_link)

    seen_links = set(woo_seen_links)
    processed_wp = set()

    for page_url in urls:
        html_text = fetch_page_html(page_url)
        if not html_text:
            continue
        _require_bs4()
        try:
            soup = BeautifulSoup(html_text, 'lxml')
        except Exception:
            soup = BeautifulSoup(html_text, 'html.parser')
        cat_text = _wordpress_collect_category_text(soup)

        name = ''
        og = soup.find('meta', property='og:title')
        if og and og.get('content'):
            name = _html_stdlib.unescape(og['content'].strip())
        if not name:
            h1 = soup.find('h1', class_=re.compile('product_title')) or soup.find('h1')
            if h1:
                name = _html_stdlib.unescape(h1.get_text(' ', strip=True))

        name = _strip_wordpress_seo_title_suffix(name, roaster_name)

        if not wordpress_product_passes_html_filters(name, html_text, cat_text):
            continue

        wp_rec = parse_wordpress_product_html(page_url, html_text, roaster_name, roaster_airtable_id)
        if not wp_rec or not wp_rec.get('Product Link'):
            continue

        canonical = wp_rec['Product Link']
        processed_wp.add(canonical)
        seen_links.add(canonical)

        if canonical in woo_records_by_link:
            record = merge_woo_primary_record(woo_records_by_link[canonical], wp_rec)
            label = '[Woo+WP merge] '
        else:
            record = wp_rec
            label = '[WP] '

        entry = existing_by_link.get(canonical)
        existing_id = entry['id'] if entry else None

        try:
            if DRY_RUN:
                if existing_id:
                    print(f'  [DRY_RUN] 🔁 Would update {label}{record.get("Product Name")}')
                else:
                    print(f'  [DRY_RUN] ✅ Would add {label}{record.get("Product Name")}')
            else:
                if existing_id:
                    products_table.update(existing_id, record, typecast=True)
                    print(f'  🔁 {label}{record.get("Product Name")}')
                else:
                    created = products_table.create(record, typecast=True)
                    existing_by_link[canonical] = {
                        'id': created['id'],
                        'roaster_text': roaster_name,
                        'roaster_ids': [str(roaster_airtable_id)] if roaster_airtable_id else [],
                    }
                    print(f'  ✅ {label}{record.get("Product Name")}')
        except Exception as e:
            print(f'  ❌ {label}{record.get("Product Name")}: {e}')

    if not defer_delete:
        delete_obsolete_products_for_roaster(roaster_name, roaster_airtable_id, seen_links, existing_by_link)

    print('\nDone with WordPress HTML pass.')
    return {'seen_links': seen_links, 'existing_by_link': existing_by_link, 'wp_only_links': processed_wp - set(woo_seen_links)}


def woo_product_to_record(p, roaster_display_name, roaster_airtable_id=None):
    """Map one WooCommerce Store API product to the same Airtable record shape as Shopify."""
    import html as _html
    name = _html.unescape(p.get('name') or '')
    # Some Woo themes include "Product - Roaster Name" style suffixes in the Woo title.
    name = _strip_wordpress_seo_title_suffix(name, roaster_display_name)
    permalink = p.get('permalink') or ''
    product_link = _canonical_product_link(permalink)
    desc = p.get('description') or ''
    short_desc = p.get('short_description') or ''
    tags_list = [t.get('name', '') for t in (p.get('tags') or [])]
    search_text = name + ' ' + desc + ' ' + short_desc + ' ' + ' '.join(tags_list)

    # Sizes and grinds from attributes (e.g. "Coffee Bag Size", "Grind")
    sizes_raw = []
    grinds_raw = []
    for attr in p.get('attributes') or []:
        attr_name = (attr.get('name') or '').lower()
        terms = attr.get('terms') or []
        values = [t.get('name') or t.get('slug', '') for t in terms]
        if 'size' in attr_name or 'weight' in attr_name or 'bag' in attr_name:
            sizes_raw.extend(values)
        elif option_name_is_grind_or_bean_type(attr_name):
            grinds_raw.extend(values)
    # Also from variations (value might be "12-oz" -> normalize to "12 oz")
    for v in p.get('variations') or []:
        for a in v.get('attributes') or []:
            an = (a.get('name') or '').lower()
            val = a.get('value') or ''
            val = val.replace('-', ' ').strip()
            if 'size' in an or 'weight' in an or 'bag' in an:
                sizes_raw.append(val)
            elif option_name_is_grind_or_bean_type(an):
                grinds_raw.append(val)

    final_roast = get_roast_level(search_text)
    final_origins = get_origins(search_text)
    final_quantities = get_quantities(sizes_raw)
    final_types = get_types(grinds_raw)
    if not final_types:
        final_types = ['Whole Bean']

    # Generic HTML structured-field fallback (platform-agnostic):
    # Use only when JSON-derived values are missing/weak.
    if permalink and (
        final_origins == ['Global'] or final_roast is None or not final_quantities or final_types == ['Whole Bean']
    ):
        html_text = fetch_page_html(permalink)
        extracted = extract_structured_fields_from_html(html_text)
        if extracted:
            if final_origins == ['Global'] and extracted.get('origin_text'):
                o2 = get_origins(extracted['origin_text'])
                if o2 and o2 != ['Global']:
                    final_origins = o2
            if final_roast is None and extracted.get('roast_text'):
                r2 = get_roast_level(extracted['roast_text'])
                if r2:
                    final_roast = r2
            if not final_quantities and extracted.get('quantity_texts'):
                q2 = get_quantities(extracted.get('quantity_texts') or [])
                if q2:
                    final_quantities = q2
            # Upgrade type if HTML shows grind options indicating ground
            if extracted.get('grind_text'):
                t2 = get_types([extracted['grind_text']])
                if t2:
                    final_types = sorted(list(set(final_types + t2)))

    if roaster_airtable_id:
        roaster_value = [roaster_airtable_id]
    else:
        roaster_value = [roaster_display_name]

    record = {
        'Product Name': name,
        'Roaster': roaster_value,
        'Product Link': product_link or permalink,
        'Origin': final_origins,
        'Quantity': final_quantities,
        'Type': final_types,
    }
    if final_roast:
        record['Roast Level'] = final_roast

    images = p.get('images') or []
    if images and images[0]:
        src = images[0].get('src')
        if src:
            record['Product Image'] = [{'url': src}]

    return record


def fetch_and_push_for_roaster(roaster_name, store_url, roaster_airtable_id=None, defer_delete=False):
    """
    Fetch, filter and upsert products for a single WooCommerce roaster.
    Intended to be called from the global orchestration code.

    If defer_delete is True, obsolete rows are not deleted here; caller should combine
    seen_links with the WordPress pass, then call delete_obsolete_products_for_roaster.

    Returns:
      - None if defer_delete is False (default).
      - dict with keys: seen_links (set), records_by_link (dict canonical -> record), existing_by_link
        if defer_delete is True.
    """
    # Load all existing records once (for upsert + roaster-specific delete).
    existing_by_link = {}
    for rec in products_table.all(fields=['Product Link', 'Roaster']):
        fields = rec.get('fields', {})
        link = fields.get('Product Link')
        if not link:
            continue
        canonical = _canonical_product_link(link)
        roaster_val = fields.get('Roaster')
        roaster_text = ''
        roaster_ids = []
        if isinstance(roaster_val, list):
            roaster_ids = [str(v) for v in roaster_val]
            roaster_text = ' '.join(roaster_ids)
        elif roaster_val is not None:
            roaster_text = str(roaster_val)
        existing_by_link[canonical] = {
            'id': rec['id'],
            'roaster_text': roaster_text,
            'roaster_ids': roaster_ids,
        }

    print(f'\n——— {roaster_name} ({store_url}) [WooCommerce] ———')
    print('Discovering products from WooCommerce sitemap/API...')
    all_products = fetch_all_woo_products(store_url)
    print(f'Retrieved {len(all_products)} product(s). Filtering...')
    coffee_products = [p for p in all_products if woo_product_passes_filters(p)]
    print(f'Found {len(coffee_products)} coffee product(s). Pushing to Airtable...\n')

    if REPLACE_ROASTER_PRODUCTS_EACH_RUN:
        replace_existing_products_for_roaster(roaster_name, roaster_airtable_id, existing_by_link)

    seen_links = set()
    records_by_link = {}
    for p in coffee_products:
        import html as _html
        name = _html.unescape(p.get('name') or '')
        record = woo_product_to_record(p, roaster_name, roaster_airtable_id)
        product_link = record.get('Product Link')
        if not product_link:
            print(f'  ⚠ Skipped {name} (missing link).')
            continue
        seen_links.add(product_link)
        records_by_link[product_link] = record
        entry = existing_by_link.get(product_link)
        existing_id = entry['id'] if entry else None

        try:
            if DRY_RUN:
                if existing_id:
                    print(f'  [DRY_RUN] 🔁 Would update: {name}')
                else:
                    print(f'  [DRY_RUN] ✅ Would add: {name}')
            else:
                if existing_id:
                    products_table.update(existing_id, record, typecast=True)
                    print(f'  🔁 Updated: {name}')
                else:
                    created = products_table.create(record, typecast=True)
                    rid = str(roaster_airtable_id) if roaster_airtable_id else ''
                    existing_by_link[product_link] = {
                        'id': created['id'],
                        'roaster_text': roaster_name,
                        'roaster_ids': [rid] if rid else [],
                    }
                    print(f'  ✅ Added: {name}')
        except Exception as e:
            print(f'  ❌ Failed {name}: {e}')

    if defer_delete:
        print('\nDone with WooCommerce roaster (delete deferred for combined WordPress pass).')
        return {
            'seen_links': seen_links,
            'records_by_link': records_by_link,
            'existing_by_link': existing_by_link,
        }

    # Delete obsolete records for this roaster only
    delete_obsolete_products_for_roaster(roaster_name, roaster_airtable_id, seen_links, existing_by_link)

    print('\nDone with WooCommerce roaster.')
    return None


def product_to_record(product, store_url, roaster_display_name, roaster_airtable_id=None):
    """Build Airtable record from Shopify product.
    Uses store_url and roaster_display_name for this roaster.
    If roaster_airtable_id is provided, the Roaster field links directly by ID.
    """
    title = product.get('title')
    # Some Shopify themes include "Product — Roaster Name" in og:title.
    # Strip the trailing roaster name suffix to keep Product Name clean.
    title = _strip_wordpress_seo_title_suffix(title, roaster_display_name)
    handle = product.get('handle')
    product_url = f'{store_url}/products/{handle}'
    vendor_raw = product.get('vendor', '')

    raw_description = product.get('body_html', '') or ''
    tags_list = product.get('tags', [])

    # 1) Prefer origins found in the product TITLE itself (e.g. "... - Colombia").
    title_text = title or ''
    title_origins = get_origins(title_text)

    # get_origins always returns at least ['Global'], so check for any real country
    has_real_title_origin = any(o != 'Global' for o in title_origins)

    # 2) Build full search text for fallback origin/roast detection
    search_text = title_text + ' ' + raw_description + ' ' + ' '.join(tags_list)

    sizes_raw = []
    grinds_raw = []
    for opt in product.get('options', []):
        opt_name = (opt.get('name') or '').lower()
        if 'size' in opt_name or 'weight' in opt_name:
            sizes_raw.extend(opt.get('values', []))
        # Shopify merchants often label this "Bean type" / "Bean Type" instead of "Grind"
        elif option_name_is_grind_or_bean_type(opt_name):
            grinds_raw.extend(opt.get('values', []))

    # Decide Roaster field: prefer explicit Airtable ID when available
    if roaster_airtable_id:
        roaster_value = [roaster_airtable_id]
    else:
        final_roaster = get_roaster_display(vendor_raw, roaster_display_name)
        roaster_value = [final_roaster]
    final_roast = get_roast_level(search_text)
    # If we found any real origin in the title, trust that list.
    # Otherwise, fall back to the existing description + tags based detection.
    if has_real_title_origin:
        final_origins = [o for o in title_origins if o != 'Global']
    else:
        final_origins = get_origins(search_text)
    final_quantities = get_quantities(sizes_raw)
    final_types = get_types(grinds_raw)
    # If we couldn't infer type from grind options, default to Whole Bean so Type is never blank.
    if not final_types:
        final_types = ['Whole Bean']

    # Generic HTML structured-field fallback (platform-agnostic):
    # Use only when JSON-derived values are missing/weak.
    if product_url and (
        final_origins == ['Global'] or final_roast is None or not final_quantities or final_types == ['Whole Bean']
    ):
        html_text = fetch_page_html(product_url)
        extracted = extract_structured_fields_from_html(html_text)
        if extracted:
            if final_origins == ['Global'] and extracted.get('origin_text'):
                o2 = get_origins(extracted['origin_text'])
                if o2 and o2 != ['Global']:
                    final_origins = o2
            if final_roast is None and extracted.get('roast_text'):
                r2 = get_roast_level(extracted['roast_text'])
                if r2:
                    final_roast = r2
            if not final_quantities and extracted.get('quantity_texts'):
                q2 = get_quantities(extracted.get('quantity_texts') or [])
                if q2:
                    final_quantities = q2
            if extracted.get('grind_text'):
                t2 = get_types([extracted['grind_text']])
                if t2:
                    final_types = sorted(list(set(final_types + t2)))

        # Tandem-specific origin extraction: origin line under the title
        # Only run if origin is still Global and this roaster is Tandem.
        if final_origins == ['Global'] and 'tandem' in (roaster_display_name or '').lower():
            soup = None
            try:
                soup = BeautifulSoup(html_text, 'lxml') if html_text else None
            except Exception:
                soup = BeautifulSoup(html_text, 'html.parser') if html_text else None
            if soup:
                # Find the main product title h1
                h1 = soup.find('h1')
                if h1:
                    # Look at a few nearby siblings for a short origin line
                    for sib in h1.find_all_next(limit=5):
                        text = sib.get_text(' ', strip=True) if hasattr(sib, 'get_text') else ''
                        if not text:
                            continue
                        o2 = get_origins(text)
                        if o2 and o2 != ['Global']:
                            final_origins = o2
                            break

    record = {
        'Product Name': title,
        'Roaster': roaster_value,
        'Product Link': product_url,
        'Origin': final_origins,
        'Quantity': final_quantities,
        'Type': final_types,
    }
    if final_roast:
        record['Roast Level'] = final_roast

    images = product.get('images') or []
    if images and images[0]:
        src = images[0].get('src')
        if src:
            record['Product Image'] = [{'url': src}]

    return record


def run_for_all_roasters():
    roasters = get_roasters_from_airtable()
    if not roasters:
        print('No roasters found in the roasters table. Check table name and field names.')
        return {'shopify': [], 'woocommerce': [], 'unknown': []}

    # Optional filter (useful for dry runs): only keep roasters matching the base_url substring
    if DRY_RUN and ROASTER_BASE_URL_SUBSTRING_FILTER:
        roasters = [
            r for r in roasters
            if (r.get('base_url') or '').lower().find(ROASTER_BASE_URL_SUBSTRING_FILTER.lower()) != -1
        ]
        if not roasters:
            print(f'[DRY_RUN] No roasters matched filter substring: {ROASTER_BASE_URL_SUBSTRING_FILTER}')
            return {'shopify': [], 'woocommerce': [], 'squarespace': [], 'wordpress': [], 'unknown': []}

    # Determine platform per roaster:
    # - Prefer the manual "Platform Used" value when present
    # - Otherwise fall back to automatic detection
    shopify_roasters = []
    woocommerce_roasters = []
    squarespace_roasters = []
    wordpress_roasters = []
    unknown_roasters = []
    for r in roasters:
        manual = (r.get('platform_used') or '').strip().lower()
        if manual == 'shopify':
            platform = 'shopify'
        elif manual in ('woocommerce', 'woocommerce', 'woo commerce', 'woo-commerce'):
            platform = 'woocommerce'
        elif manual in ('squarespace', 'square space', 'square-space'):
            platform = 'squarespace'
        else:
            platform = detect_platform(r['base_url'])
        r['platform'] = platform
        if platform == 'shopify':
            shopify_roasters.append(r)
        elif platform == 'woocommerce':
            woocommerce_roasters.append(r)
        elif platform == 'squarespace':
            squarespace_roasters.append(r)
        else:
            unknown_roasters.append(r)

        # Independently check for WordPress traces; if found, also mark for WordPress scraping.
        try:
            if is_wordpress_site(r['base_url']):
                wordpress_roasters.append(r)
        except Exception:
            pass

    # Load all existing product records once (for upsert + safe delete for Shopify stores)
    existing_by_link = {}
    wordpress_id_set = set([str(r.get('id')) for r in wordpress_roasters if r.get('id')])
    shopify_pass_results_by_id = {}
    for rec in products_table.all(fields=['Product Link', 'Roaster']):
        fields = rec.get('fields', {})
        link = fields.get('Product Link')
        if not link:
            continue
        roaster_val = fields.get('Roaster')
        roaster_text = ''
        roaster_ids = []
        if isinstance(roaster_val, list):
            roaster_ids = [str(v) for v in roaster_val]
            roaster_text = ' '.join(roaster_ids)
        elif roaster_val is not None:
            roaster_text = str(roaster_val)
        existing_by_link[link] = {
            'id': rec['id'],
            'roaster_display': roaster_text,
            'roaster_ids': roaster_ids,
        }

    # Process only Shopify roasters with the Shopify scraper
    for roaster in shopify_roasters:
        name = roaster['name']
        store_url = roaster['base_url']
        roaster_id = roaster.get('id')
        print(f"\n——— {name} ({store_url}) [Shopify] ———")
        print('Discovering products from sitemap...')
        coffee_products = get_all_coffee_products_for_store(store_url, name, roaster_id)
        print(f"Found {len(coffee_products)} coffee product(s). Upserting...\n")

        # Optional "clobber then insert" mode: remove this roaster's current rows before
        # recreating the freshly scraped set so records stay grouped together in Airtable.
        if REPLACE_ROASTER_PRODUCTS_EACH_RUN:
            links_to_replace = [
                link for link, meta in existing_by_link.items()
                if (
                    (roaster_id and roaster_id in meta.get('roaster_ids', []))
                    or roaster_display_matches(meta.get('roaster_display', ''), name)
                )
            ]
            if links_to_replace:
                print(f"  Replacing {len(links_to_replace)} existing record(s) for {name}...")
                if DRY_RUN:
                    print(f'  [DRY_RUN] Would delete {len(links_to_replace)} existing record(s) before re-add.')
                else:
                    ids_to_delete = [existing_by_link[link]['id'] for link in links_to_replace]
                    for i in range(0, len(ids_to_delete), 10):
                        batch = ids_to_delete[i : i + 10]
                        try:
                            products_table.batch_delete(batch)
                            print(f"  🗑️ Deleted {len(batch)} record(s) for replace mode.")
                        except Exception as e:
                            print(f"  ❌ Replace-mode batch delete failed: {e}")
                            for rid in batch:
                                try:
                                    products_table.delete(rid)
                                    print("  🗑️ Deleted 1 record (replace fallback).")
                                except Exception as e2:
                                    msg = str(e2)
                                    if 'NOT_FOUND' in msg or '404' in msg:
                                        print("  ℹ️ Skip missing record (replace fallback).")
                                    else:
                                        print(f"  ❌ Replace fallback delete failed: {e2}")
                for link in links_to_replace:
                    existing_by_link.pop(link, None)

        seen_links = set()
        seen_links_canonical = set()
        records_by_link_canonical = {}
        for product in coffee_products:
            title = product.get('title')
            record = product_to_record(product, store_url, name, roaster_airtable_id=name and roaster.get('id'))
            product_link = record.get('Product Link')
            if not product_link:
                continue
            seen_links.add(product_link)
            canonical_link = _canonical_product_link(product_link)
            seen_links.add(canonical_link)
            seen_links_canonical.add(canonical_link)
            records_by_link_canonical[canonical_link] = record
            entry = existing_by_link.get(product_link)
            existing_id = entry['id'] if entry else None

            try:
                if DRY_RUN:
                    if existing_id:
                        print(f"  [DRY_RUN] 🔁 Would update: {title}")
                    else:
                        print(f"  [DRY_RUN] ✅ Would add: {title}")
                else:
                    if existing_id:
                        products_table.update(existing_id, record, typecast=True)
                        print(f"  🔁 Updated: {title}")
                    else:
                        created = products_table.create(record, typecast=True)
                        existing_by_link[product_link] = {
                            'id': created['id'],
                            'roaster_display': name,
                            'roaster_ids': [str(roaster_id)] if roaster_id else [],
                        }
                        print(f"  ✅ Added: {title}")
            except Exception as e:
                print(f"  ❌ Failed {title}: {e}")

        # Delete only this roaster's records that are no longer on the site
        # If WordPress is also detected for this roaster, we defer deletion.
        # The WordPress pass will delete using the union of Woo/Shopify + WordPress links.
        if roaster_id and str(roaster_id) in wordpress_id_set:
            shopify_pass_results_by_id[str(roaster_id)] = {
                'seen_links': seen_links_canonical,
                'records_by_link': records_by_link_canonical,
            }
        else:
            links_to_delete = [
                link for link, meta in existing_by_link.items()
                if (
                    (roaster_id and roaster_id in meta.get('roaster_ids', []))
                    or roaster_display_matches(meta['roaster_display'], name)
                ) and link not in seen_links
            ]
            if links_to_delete:
                print(f"\n  Deleting {len(links_to_delete)} obsolete record(s) for {name}...")
                if DRY_RUN:
                    print(f'  [DRY_RUN] Would delete {len(links_to_delete)} record(s).')
                    shopify_pass_results_by_id[str(roaster_id)] = {
                        'seen_links': seen_links_canonical,
                        'records_by_link': records_by_link_canonical,
                    }
                    continue
                ids_to_delete = [existing_by_link[link]['id'] for link in links_to_delete]
                for i in range(0, len(ids_to_delete), 10):
                    batch = ids_to_delete[i : i + 10]
                    try:
                        products_table.batch_delete(batch)
                        print(f"  🗑️ Deleted {len(batch)} record(s).")
                    except Exception as e:
                        print(f"  ❌ Batch delete failed: {e}")
                        # Airtable batch_delete fails the whole request if *any* record ID
                        # in the batch is missing. Retry individually so we still clean up
                        # the IDs that do exist.
                        for rid in batch:
                            try:
                                products_table.delete(rid)
                                print("  🗑️ Deleted 1 record (fallback).")
                            except Exception as e2:
                                msg = str(e2)
                                if 'NOT_FOUND' in msg or '404' in msg:
                                    print("  ℹ️ Skip missing record (fallback).")
                                else:
                                    print(f"  ❌ Fallback delete failed: {e2}")
            shopify_pass_results_by_id[str(roaster_id)] = {
                'seen_links': seen_links_canonical,
                'records_by_link': records_by_link_canonical,
            }

    print('\nDone with Shopify roasters.')
    return {
        'shopify': shopify_roasters,
        'woocommerce': woocommerce_roasters,
        'squarespace': squarespace_roasters,
        'wordpress': wordpress_roasters,
        'unknown': unknown_roasters,
        'shopify_pass_results_by_id': shopify_pass_results_by_id,
    }


if __name__ == '__main__':
    # Run scrapers for all roasters listed in Roaster Information,
    # automatically routing Shopify/WooCommerce/Squarespace based on platform detection.
    platforms = run_for_all_roasters()

    woocommerce_roasters = platforms.get('woocommerce', []) if platforms else []
    squarespace_roasters = platforms.get('squarespace', []) if platforms else []
    shopify_roasters = platforms.get('shopify', []) if platforms else []
    wordpress_roasters = platforms.get('wordpress', []) if platforms else []
    shopify_pass_results_by_id = platforms.get('shopify_pass_results_by_id', {}) if platforms else {}

    # Match by normalized host so https://cutbowcoffee.com matches https://www.cutbowcoffee.com
    wordpress_base_set = set(
        _canonical_roaster_host(r.get('base_url'))
        for r in wordpress_roasters
        if _canonical_roaster_host(r.get('base_url'))
    )

    def is_wordpress_trace(roaster):
        h = _canonical_roaster_host(roaster.get('base_url'))
        return bool(h and h in wordpress_base_set)

    # 1) WooCommerce: always run the WordPress HTML pass after the Store API pass.
    # WooCommerce stores run on WordPress; the HTML/sitemap pass discovers URLs the Store API
    # often misses (e.g. Cutbow). We do not rely on is_wordpress_site() for this path.
    for r in woocommerce_roasters:
        print(f"\nRouting {r['name']} ({r['base_url']}) to WooCommerce scraper...")
        try:
            woo_res = fetch_and_push_for_roaster(
                roaster_name=r['name'],
                store_url=r['base_url'],
                roaster_airtable_id=r['id'],
                defer_delete=True,
            )
            fetch_and_push_wordpress_for_roaster(
                roaster_name=r['name'],
                store_url=r['base_url'],
                roaster_airtable_id=r['id'],
                woo_seen_links=woo_res.get('seen_links', set()),
                woo_records_by_link=woo_res.get('records_by_link', {}),
                defer_delete=False,
            )
        except Exception as e:
            print(f"\n⚠️ Skipping roaster {r['name']} due to error: {e}")

    # 2) Shopify primary pass already happened inside run_for_all_roasters.
    #    If WordPress traces exist too, run the WordPress HTML pass after Shopify,
    #    using Shopify results as the primary source and deferring deletions in Shopify.
    for r in shopify_roasters:
        if not is_wordpress_trace(r):
            continue
        roaster_id = r.get('id')
        primary = shopify_pass_results_by_id.get(str(roaster_id), {})
        try:
            fetch_and_push_wordpress_for_roaster(
                roaster_name=r['name'],
                store_url=r['base_url'],
                roaster_airtable_id=roaster_id,
                woo_seen_links=primary.get('seen_links', set()),
                woo_records_by_link=primary.get('records_by_link', {}),
                defer_delete=False,
            )
        except Exception as e:
            print(f"\n⚠️ Skipping roaster {r['name']} due to error: {e}")

    # 3) Squarespace roasters run the generic Squarespace HTML/sitemap pass.
    for r in squarespace_roasters:
        print(f"\nRouting {r['name']} ({r['base_url']}) to Squarespace scraper...")
        try:
            fetch_and_push_squarespace_for_roaster(
                roaster_name=r['name'],
                store_url=r['base_url'],
                roaster_airtable_id=r.get('id'),
            )
        except Exception as e:
            print(f"\n⚠️ Skipping roaster {r['name']} due to error: {e}")

    # Log any roasters where platform could not be determined
    unknown_roasters = platforms.get('unknown', []) if platforms else []
    for r in unknown_roasters:
        print(f"\n⚠️ Platform unknown for {r['name']} ({r['base_url']}). Skipping.")
